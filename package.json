{
  "name": "techmate-agent",
  "version": "1.0.0",
  "private": true,
  "description": "TechMate - 技术学习陪伴Agent，帮助开发者提升前端技术能力",
  "scripts": {
    "dev": "pnpm --filter @tech-mate/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "pnpm -r type-check",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "prepare": "husky install || true"
  },
  "keywords": [
    "ai",
    "agent",
    "langgraph",
    "rag",
    "mcp",
    "tech-learning",
    "前端开发",
    "React",
    "TypeScript"
  ],
  "author": "sxh",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "husky": "^8.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
