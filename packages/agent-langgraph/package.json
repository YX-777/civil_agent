    "@tech-mate/mcp-bailian-rag": "workspace:*",
    "@tech-mate/mcp-xiaohongshu": "workspace:*",
    "@tech-mate/rag-engine": "workspace:*",
    "axios": "^1.6.5",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^17.2.3",
    "llamaindex": "^0.11.0",
    "undici": "^6.21.0",
    "zod": "^3.25.0"
