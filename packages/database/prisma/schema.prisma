generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile           UserProfile?
  conversations     Conversation[]
  tasks             Task[]
  focusSessions     FocusSession[]
  learningRecords   LearningRecord[]
  moduleProgress    ModuleProgress[]
  agentStates       AgentState[]
  embeddings        Embedding[]
  shortTermMemories ShortTermMemory[]
  metaMemory        MetaMemory?

  @@map("users")
}

model UserProfile {
  userId          String   @id @map("user_id")
  nickname         String   @default("学习者")
  targetScore      Int      @default(75) @map("target_score")
  examDate        DateTime? @map("exam_date")
  totalStudyDays   Int      @default(0) @map("total_study_days")
  avatarUrl       String?  @map("avatar_url")
  bio             String?
  learningStyle    String?  @map("learning_style")
  dailyGoalHours  Float    @default(4.0) @map("daily_goal_hours")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("user_profiles")
}

model Conversation {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  summary   String?
  vectorCollectionId String? @map("vector_collection_id")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, updatedAt(sort: Desc)])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid())
  conversationId  String   @map("conversation_id")
  role           String
  content        String
  timestamp      DateTime @default(now())
  embeddingId     String?  @map("embedding_id")
  metadata       String?
  tokenCount     Int      @default(0) @map("token_count")
  modelVersion   String?  @map("model_version")

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, timestamp])
  @@map("messages")
}

model Task {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  title       String
  description String?
  status      String    @default("todo")
  progress    Int       @default(0)
  dueDate     DateTime? @map("due_date")
  priority    Int       @default(1)
  module      String?
  difficulty  String?
  estimatedMinutes Int?  @map("estimated_minutes")
  actualMinutes   Int?  @map("actual_minutes")
  tags        String?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  completedAt DateTime? @map("completed_at")

  @@index([userId, status, dueDate])
  @@index([priority])
  @@map("tasks")
}

model FocusSession {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  duration  Int
  module    String
  completed Boolean   @default(false)
  startTime DateTime  @map("start_time")
  endTime   DateTime? @map("end_time")
  notes     String?
  interruptionCount Int  @default(0) @map("interruption_count")
  moodBefore  String?  @map("mood_before")
  moodAfter   String?  @map("mood_after")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId, startTime(sort: Desc)])
  @@index([completed])
  @@map("focus_sessions")
}

model LearningRecord {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  date              DateTime @default(now())
  learningHours      Float    @default(0) @map("learning_hours")
  completed         Boolean  @default(false)
  tasksCompleted     Int      @default(0) @map("tasks_completed")
  questionsAnswered  Int      @default(0) @map("questions_answered")
  accuracy          Float?
  notes             String?
  mood              String?
  energyLevel       Int?     @map("energy_level")

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@unique([userId, date])
  @@index([userId, date(sort: Desc)])
  @@map("learning_records")
}

model ModuleProgress {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  moduleName        String   @map("module_name")
  totalQuestions    Int      @default(0) @map("total_questions")
  correctAnswers    Int      @default(0) @map("correct_answers")
  accuracy          Float    @default(0)
  progressPercentage Int      @default(0) @map("progress_percentage")
  lastPracticedAt   DateTime? @map("last_practiced_at")
  weakPoints        String?  @map("weak_points")
  strongPoints      String?  @map("strong_points")

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@unique([userId, moduleName])
  @@index([userId, accuracy(sort: Desc)])
  @@map("module_progress")
}

model AgentState {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  conversationId  String   @map("conversation_id")
  stateData       String   @map("state_data")
  contextVectorId String?  @map("context_vector_id")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@unique([userId, conversationId])
  @@index([updatedAt])
  @@map("agent_states")
}

model Embedding {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  vectorDbId     String   @map("vector_db_id")
  vectorType     String   @map("vector_type")
  contentType    String   @map("content_type")
  contentSummary String?  @map("content_summary")

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([vectorType])
  @@index([vectorDbId])
  @@map("embeddings")
}

model XhsPost {
  id           String   @id @default(uuid())
  postId       String   @unique @map("post_id")
  xsecToken    String?  @map("xsec_token")
  title        String
  contentRaw   String   @map("content_raw")
  contentClean String   @map("content_clean")
  contentHash  String   @map("content_hash")
  authorId     String?  @map("author_id")
  authorName   String?  @map("author_name")
  publishTime  DateTime? @map("publish_time")
  likeCount    Int      @default(0) @map("like_count")
  commentCount Int      @default(0) @map("comment_count")
  collectCount Int      @default(0) @map("collect_count")
  shareCount   Int      @default(0) @map("share_count")
  sourceUrl    String?  @map("source_url")
  tags         String?
  status       String   @default("new")
  errorMessage String?  @map("error_message")
  bailianDocId String?  @map("bailian_doc_id")
  uploadedAt   DateTime? @map("uploaded_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([contentHash])
  @@index([status])
  @@index([publishTime])
  @@map("xhs_posts")
}

model XhsSyncRun {
  id                String   @id @default(uuid())
  jobName           String   @default("weekly-xiaohongshu-sync") @map("job_name")
  status            String   @default("running")
  requestedLimit    Int      @default(0) @map("requested_limit")
  fetchedCount      Int      @default(0) @map("fetched_count")
  insertedCount     Int      @default(0) @map("inserted_count")
  dedupedPostIdCount Int     @default(0) @map("deduped_post_id_count")
  dedupedHashCount  Int      @default(0) @map("deduped_hash_count")
  invalidCount      Int      @default(0) @map("invalid_count")
  failedCount       Int      @default(0) @map("failed_count")
  errorMessage      String?  @map("error_message")
  reportJson        String?  @map("report_json")
  startedAt         DateTime @default(now()) @map("started_at")
  endedAt           DateTime? @map("ended_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([jobName, createdAt(sort: Desc)])
  @@index([status])
  @@map("xhs_sync_runs")
}

// ==================== 四阶分层记忆系统 ====================

/// 短期记忆：7天内对话，新鲜度衰减机制
model ShortTermMemory {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  conversationId  String   @map("conversation_id")

  // 记忆内容
  content         String                        // 消息摘要或关键信息
  contentType     String   @map("content_type") // "message", "topic", "emotion"

  // 衰减相关
  createdAt       DateTime @default(now()) @map("created_at")
  lastAccessedAt  DateTime @default(now()) @map("last_accessed_at")
  freshnessScore  Float    @default(1.0) @map("freshness_score") // 新鲜度 0-1
  accessCount     Int      @default(0) @map("access_count")      // 访问次数

  // 话题关联
  topicTags       String?  @map("topic_tags")    // JSON 数组：["React", "面试"]
  relatedTopics   String?  @map("related_topics") // 关联话题 ID

  // 向量关联
  vectorId        String?  @map("vector_id")

  // 状态
  archived        Boolean  @default(false) @map("archived") // 是否已归档到长期记忆

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, freshnessScore])
  @@index([archived])
  @@map("short_term_memories")
}

/// 元记忆：用户画像 + 技能图谱聚合
model MetaMemory {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")

  // 能力图谱
  skillGraph      String   @map("skill_graph")    // JSON：技能树和熟练度
  weakAreas       String   @map("weak_areas")     // JSON：薄弱项列表
  strongAreas     String   @map("strong_areas")   // JSON：强项列表

  // 学习偏好
  learningStyle   String?  @map("learning_style") // "visual", "reading", "practice"
  preferredTime   String?  @map("preferred_time") // "morning", "afternoon", "evening"
  dailyGoal       Float?   @map("daily_goal")     // 每日目标小时数

  // 学习统计
  totalHours      Float    @default(0) @map("total_hours")
  consecutiveDays Int      @default(0) @map("consecutive_days")
  averageAccuracy Float    @default(0) @map("average_accuracy")

  // 情绪模式
  emotionalPattern String? @map("emotional_pattern") // JSON：常见情绪和应对策略

  // 向量关联（用于相似用户匹配）
  vectorId        String?  @map("vector_id")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("meta_memories")
}
